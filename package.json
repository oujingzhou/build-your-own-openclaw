    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.35.0",
    "eventemitter3": "^5.0.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "openai": "^4.85.4",
    "readline": "^1.3.0",
    "ws": "^8.18.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
