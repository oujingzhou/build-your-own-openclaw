{
  "name": "build-your-own-openclaw",
  "version": "1.0.0",
  "description": "Build Your Own OpenClaw - A step-by-step tutorial to build a multi-channel AI assistant gateway",
  "type": "module",
  "bin": {
    "myclaw": "./myclaw.mjs"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
